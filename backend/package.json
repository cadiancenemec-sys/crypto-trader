{
  "name": "kraken-trader-backend",
  "version": "1.0.0",
  "description": "Kraken ETH Trading Backend - Low Fee Trading (0.16%)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "monitor": "node backend/monitor-pending.js",
    "monitor:pm2": "pm2 start ecosystem.config.js",
    "monitor:restart": "pm2 restart order-monitor",
    "monitor:logs": "pm2 logs order-monitor --lines 50",
    "monitor:start": "pm2 start backend/monitor-pending.js --name order-monitor",
    "monitor:stop": "pm2 stop order-monitor"
  },
  "dependencies": {
    "binance-api-node": "^0.13.8",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "kraken-api": "^1.0.2"
  },
  "author": "Don",
  "license": "MIT"
}
