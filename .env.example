# Binance.US API Keys (get from https://www.binance.us/en/settings/api-management)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Server Ports
PORT=3003
WS_PORT=8080

# Trading Config
DEFAULT_SYMBOL=BTCUSD
CHECK_INTERVAL_MS=60000
PENDING_ORDER_CHECK_MS=180000

# Logging
LOG_LEVEL=info